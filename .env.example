# Darius Star: Cyber Coelacanth — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real secrets.

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Google Cloud / Vertex AI (for Veo 3.1 + Imagen + Lyria)
GCP_PROJECT=darius-star-game
GCP_LOCATION=us-central1
# Use gcloud auth or set GOOGLE_APPLICATION_CREDENTIALS

# Antigravity OAuth token path (Veo client)
# Default: ~/.gemini/antigravity-cli/antigravity-oauth-token
ANTIGRAVITY_TOKEN_PATH=

# Prismatic Engine
PRISMATIC_HOME=/home/ubuntu
